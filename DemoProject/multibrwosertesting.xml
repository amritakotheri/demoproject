<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="multibrowsertesting" parallel="tests">
  <test thread-count="5" name="Chrometest">
  <parameter name="browser" value="Chrome"></parameter>
    <classes>
      <class name="testscript.LoginTest">
      <methods>
      <include name="verifyTheUserIsAbleToLoginUsingInvalidUsernameValidPassword"></include>
      <include name="verifyTheUserIsAbleToLoginUsingValidUsernameInvalidPassword"></include>
      </methods>
      </class>
    </classes>
  </test> <!-- Test -->
   <test thread-count="5" name="Firefoxtest">
   <parameter name="browser" value="Firefox"></parameter>
    <classes>
      <class name="testscript.LoginTest">
      <methods>
      <include name="verifyTheUserIsAbleToLoginUsingInvalidUsernameValidPassword"></include>
      <include name="verifyTheUserIsAbleToLoginUsingValidUsernameInvalidPassword"></include>
      </methods>
      </class>
    </classes>
  </test> <!-- Test -->
</suite> <!-- Suite -->
